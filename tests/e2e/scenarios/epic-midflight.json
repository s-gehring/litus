{
	"name": "epic-midflight",
	"claude": [
		{
			"delayMs": 3000,
			"events": [
				{ "type": "system", "subtype": "init", "session_id": "epic-midflight-analyzer" },
				{
					"type": "result",
					"subtype": "success",
					"session_id": "epic-midflight-analyzer",
					"result": "```json\n{\"title\":\"Never arrives\",\"specs\":[]}\n```"
				}
			]
		}
	],
	"gh": {
		"--version": { "exitCode": 0, "stdout": "gh version 2.60.0 (litus-e2e-fake)\n" },
		"auth status": { "exitCode": 0, "stdout": "Logged in to github.com as e2e-fake-user\n" },
		"pr list": { "exitCode": 0, "stdout": "[]" },
		"pr view": {
			"exitCode": 0,
			"stdout": "{\"state\":\"OPEN\",\"url\":\"https://github.com/example/repo/pull/42\",\"number\":42}"
		},
		"pr merge": { "exitCode": 0, "stdout": "Merged pull request #42 (Squash and merge)\n" },
		"pr checks": {
			"exitCode": 0,
			"stdout": "[{\"name\":\"build\",\"state\":\"SUCCESS\",\"bucket\":\"pass\"}]"
		},
		"pr create": {
			"exitCode": 0,
			"stdout": "https://github.com/example/repo/pull/42\n"
		},
		"run view": { "exitCode": 0, "stdout": "" }
	}
}
