{
	"name": "retry-after-error",
	"claude": [
		{
			"events": [
				{ "type": "system", "subtype": "init", "session_id": "sess-specify-fail" },
				{
					"type": "result",
					"subtype": "error",
					"session_id": "sess-specify-fail",
					"result": "Scripted specify failure — the next invocation is the retry."
				}
			],
			"exitCode": 1
		},
		{
			"events": [
				{ "type": "system", "subtype": "init", "session_id": "sess-specify-retry" },
				{
					"type": "assistant",
					"session_id": "sess-specify-retry",
					"message": {
						"content": [{ "type": "text", "text": "Specification drafted (retry)." }]
					}
				},
				{
					"type": "result",
					"subtype": "success",
					"session_id": "sess-specify-retry",
					"result": "Specification drafted (retry)."
				}
			]
		},
		{
			"events": [
				{ "type": "system", "subtype": "init", "session_id": "sess-clarify" },
				{
					"type": "assistant",
					"session_id": "sess-clarify",
					"message": {
						"content": [
							{ "type": "text", "text": "Question 1: Should the feature support dark mode?" }
						]
					}
				},
				{
					"type": "result",
					"subtype": "success",
					"session_id": "sess-clarify",
					"result": "Question 1: Should the feature support dark mode?"
				}
			]
		},
		{ "text": "yes\n" }
	],
	"gh": {
		"--version": { "exitCode": 0, "stdout": "gh version 2.60.0 (litus-e2e-fake)\n" },
		"auth status": { "exitCode": 0, "stdout": "Logged in to github.com as e2e-fake-user\n" }
	}
}
