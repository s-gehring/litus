{
  "name": "litus",
  "version": "1.0.0",
  "description": "A web-based orchestrator for Claude Code agents",
  "author": "Simon Gehring",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/s-gehring/litus.git"
  },
  "keywords": [
    "claude-code",
    "ai-agent",
    "orchestrator",
    "pipeline",
    "bun",
    "typescript"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@happy-dom/global-registrator": "^20.8.9",
    "@playwright/test": "^1.48.0",
    "@types/bun": "^1.3.11",
    "happy-dom": "^20.8.9"
  },
  "scripts": {
    "dev": "bun run build:client && bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build:client": "bun run src/build.ts",
    "test": "bun test tests/unit tests/integration tests/client",
    "build:e2e-fakes": "bun run tests/e2e/build-fakes.ts",
    "test:e2e": "bun run build:e2e-fakes && bun run build:client && bunx playwright test -c tests/e2e/playwright.config.ts",
    "lint": "bunx biome lint .",
    "format": "bunx biome format .",
    "format:check": "bunx biome format --check ."
  },
  "engines": {
    "bun": ">=1.3.11"
  },
  "type": "module",
  "dependencies": {
    "dompurify": "^3.4.0",
    "marked": "^18.0.3"
  }
}
